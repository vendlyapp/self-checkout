{
  "mcpServers": {
    "supabase-vendly": {
      "command": "mcp-server-supabase",
      "args": ["--access-token", "YOUR_SUPABASE_ACCESS_TOKEN"]
    },
    "github": {
      "command": "mcp-server-github",
      "env": {
        "GITHUB_TOKEN": "YOUR_GITHUB_PERSONAL_ACCESS_TOKEN"
      }
    },
    "shadcn": {
      "command": "npx",
      "args": ["shadcn", "mcp"]
    }
  }
}

# Supabase Configuration (REQUIRED)
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
# REQUIRED in production. Service role key for admin operations (user cache, super-admin queries)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Database Configuration (REQUIRED)
# Runtime (Express pool): Supabase Transaction pooler — port 6543, ?pgbouncer=true
# Example: postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=your_postgres_pooler_connection_string
# Migrations / DDL only: direct connection — port 5432 (never use for app traffic in production)
# DIRECT_URL=postgresql://postgres.[ref]:[password]@db.[ref].supabase.co:5432/postgres

# Server Configuration
PORT=3001
NODE_ENV=development

# CORS Configuration (REQUIRED in production)
# Comma-separated list of allowed origins. Examples: https://example.com,https://app.example.com
# If not set in production, server will fail to start
CORS_ORIGIN=http://localhost:3000

# Frontend URL (for redirects in auth flows)
FRONTEND_URL=http://localhost:3000

# Google OAuth (Optional - ya está configurado en Supabase Dashboard)
# Solo necesario si quieres usarlo en el backend directamente
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
SUPER_ADMIN_EMAIL=CHANGE_ME@yourdomain.com
SUPER_ADMIN_PASSWORD=CHANGE_ME_use_a_strong_password
# Copiar a .env.local para desarrollo. En Vercel: Settings → Environment Variables (Production + Preview).
# NEXT_PUBLIC_* se embeben en el build — tras cambiarlas, hacer Redeploy sin caché.

# Backend Fly.io (NO usar localhost en producción)
NEXT_PUBLIC_API_URL=https://self-checkout-9a4fzg.fly.dev

# Supabase (mismo proyecto que el backend)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# URL pública del frontend (OAuth redirects, QR de tienda)
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Opcional: hostname de Storage para next/image (sin https://)
# NEXT_PUBLIC_SUPABASE_HOSTNAME=YOUR_PROJECT.supabase.co

# NO poner en el frontend: DATABASE_URL, SUPABASE_SERVICE_ROLE_KEY, secrets de Google OAuth
